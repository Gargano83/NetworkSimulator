@using NetworkSimulator.Desktop.Services
@using NetworkSimulator.Shared
@using System.Text.Json
@inject AnalysisStateService AnalysisState
@inject IJSRuntime JSRuntime
@implements IDisposable

<button class="btn btn-secondary btn-sm mb-3" @onclick="ClearResults">Azzera Risultati Analisi</button>

<div class="accordion" id="analysisAccordion">
    <!-- Caso di Studio 1 -->
    <div class="accordion-item" id="card-normal-conditions">
        <h2 class="accordion-header" id="heading1">
            <div class="d-flex w-100">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1" aria-expanded="true" aria-controls="collapse1">
                    Caso di Studio 1: Condizioni Normali
                </button>
                <button class="btn btn-sm btn-outline-secondary ms-auto me-2 my-auto" @onclick='() => ExportCardAsImage("card-normal-conditions", "condizioni-normali.png")' title="Salva come immagine">
                    <i class="bi bi-printer"></i>
                </button>
            </div>
        </h2>
        <div id="collapse1" class="accordion-collapse collapse show" aria-labelledby="heading1">
            <div class="accordion-body">
                <p class="small text-muted">Esegui una simulazione completa per ogni algoritmo per popolare la tabella.</p>
                <h6 class="mt-3">Dijkstra (Baseline)</h6>
                @if (AnalysisState.NormalConditionFlowResults.TryGetValue("Dijkstra", out var dijkstraFlows) && dijkstraFlows.Any())
                {
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Sorgente</th>
                                <th>Percorso Calcolato</th>
                                <th>Tasso Consegna (%)</th>
                                <th>Latenza Media (ms)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var flow in dijkstraFlows)
                            {
                                <tr>
                                    <td>@GetNodeLabel(flow.SourceNodeId)</td>
                                    <td>@FormatDetailedPath(flow.FinalPath)</td>
                                    <td>@flow.DeliveryRate.ToString("F2")%</td>
                                    <td>@flow.AverageLatency.ToString("F0") ms</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="small text-muted fst-italic">Nessun dato disponibile per Dijkstra.</p>
                }
                <h6 class="mt-4">AI (Q-Learning)</h6>
                @if (AnalysisState.NormalConditionFlowResults.TryGetValue("AI", out var aiFlows) && aiFlows.Any())
                {
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Sorgente</th>
                                <th>Percorso Calcolato</th>
                                <th>Tasso Consegna (%)</th>
                                <th>Latenza Media (ms)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var flow in aiFlows)
                            {
                                <tr>
                                    <td>@GetNodeLabel(flow.SourceNodeId)</td>
                                    <td>@FormatDetailedPath(flow.FinalPath)</td>
                                    <td>@flow.DeliveryRate.ToString("F2")%</td>
                                    <td>@flow.AverageLatency.ToString("F0") ms</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="small text-muted fst-italic">Nessun dato disponibile per l'AI.</p>
                }
            </div>
        </div>
    </div>
    <!-- Caso di Studio Extra -->
    <div class="accordion-item" id="card-scalability">
        <h2 class="accordion-header" id="headingScalability">
            <div class="d-flex w-100">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExtra" aria-expanded="false" aria-controls="collapseExtra">
                    Caso di Studio Extra: Analisi di Scalabilità
                </button>
                <button class="btn btn-sm btn-outline-secondary ms-auto me-2 my-auto" @onclick='() => ExportCardAsImage("card-scalability", "scalability-analysis.png")' title="Salva come immagine">
                    <i class="bi bi-printer"></i>
                </button>
            </div>
        </h2>
        <div id="collapseExtra" class="accordion-collapse collapse" aria-labelledby="headingScalability">
            <div class="accordion-body">
                <p class="small text-muted">Analisi dell'andamento della latenza all'aumentare del carico (numero di sensori).</p>
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-center mt-3">Latenza Media</h6>
                        <div style="height: 300px;">
                            <canvas id="scalabilityChart"></canvas>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-center mt-3">Tasso di Consegna</h6>
                        <div style="height: 300px;">
                            <canvas id="scalabilityDeliveryChart"></canvas>
                        </div>
                    </div>
                </div>
                @if (AnalysisState.ScalabilityResults.Any())
                {
                    <div class="table-responsive mt-4">
                        <table class="table table-sm table-bordered text-center table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Algoritmo</th>
                                    <th>Data Rate</th>
                                    <th>N. Sensori</th>
                                    <th>Latenza Media (ms)</th>
                                    <th>Tasso Consegna (%)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in AnalysisState.ScalabilityResults.OrderBy(r => r.Algorithm).ThenBy(r => r.DataRate).ThenBy(r => r.SensorCount).ToList())
                                {
                                    <tr>
                                        <td class="fw-bold">@result.Algorithm</td>
                                        <td>@result.DataRate KB/s</td>
                                        <td>@result.SensorCount</td>
                                        <td>@result.AverageLatency.ToString("F2")</td>
                                        <td>@result.DeliveryRate.ToString("F2")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted fst-italic py-3">
                        Nessun dato di scalabilità. Esegui un test batch dal pannello di controllo.
                    </div>
                }
            </div>
        </div>
    </div>
    <!-- Caso di Studio 2 -->
    <div class="accordion-item" id="card-link-failure">
        <h2 class="accordion-header" id="heading2">
            <div class="d-flex w-100">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2" aria-expanded="false" aria-controls="collapse2">
                    Caso di Studio 2: Guasto di un Link (Link Failure)
                </button>
                <button class="btn btn-sm btn-outline-secondary ms-auto me-2 my-auto" @onclick='() => ExportCardAsImage("card-link-failure", "guasto-link.png")' title="Salva come immagine">
                    <i class="bi bi-printer"></i>
                </button>
            </div>
        </h2>
        <div id="collapse2" class="accordion-collapse collapse" aria-labelledby="heading2">
            <div class="accordion-body">
                <p class="small text-muted">Esegui lo scenario di guasto per ogni algoritmo per popolare il grafico. I dati vengono aggiunti in tempo reale.</p>
                <canvas id="linkFailureChart"></canvas>
                @if (AnalysisState.LinkFailureFlowResults.Values.Any(flowDict => flowDict.Any()))
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-bordered text-center align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Serie</th>
                                    @foreach (var timePoint in AnalysisState.LinkFailureFlowResults.First().Value.First().Value)
                                    {
                                        <th>@timePoint.Time s</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var algEntry in AnalysisState.LinkFailureFlowResults.ToList())
                                {
                                    @foreach (var flowEntry in algEntry.Value.ToList())
                                    {
                                        <tr>
                                            <td class="fw-bold text-start ps-2">@algEntry.Key - @GetNodeLabel(flowEntry.Key)</td>
                                            @foreach (var dataPoint in flowEntry.Value)
                                            {
                                                <td>@dataPoint.DeliveryRate.ToString("F2")</td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted fst-italic py-5">
                        <p>Nessun dato disponibile.<br>Abilita lo scenario di guasto nel pannello "Controllo Simulazione" prima di avviare una simulazione per vedere i risultati.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <!-- Caso di Studio 3 -->
    <div class="accordion-item" id="card-congestion">
        <h2 class="accordion-header" id="heading3">
            <div class="d-flex w-100">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3" aria-expanded="false" aria-controls="collapse3">
                    Caso di Studio 3: Congestione
                </button>
                <button class="btn btn-sm btn-outline-secondary ms-auto me-2 my-auto" @onclick='() => ExportCardAsImage("card-congestion", "congestione.png")' title="Salva come immagine">
                    <i class="bi bi-printer"></i>
                </button>
            </div>
        </h2>
        <div id="collapse3" class="accordion-collapse collapse" aria-labelledby="heading3">
            <div class="accordion-body">
                <p class="small text-muted">Questa sezione è predisposta per future analisi sulla congestione di rete.</p>
                <canvas id="congestionChart"></canvas>
                @if (AnalysisState.CongestionTestResults.Values.Any(flowDict => flowDict.Any()))
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-bordered text-center align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Serie</th>
                                    @foreach (var timePoint in AnalysisState.CongestionTestResults.First().Value.First().Value)
                                    {
                                        <th>@timePoint.Time s</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var algEntry in AnalysisState.CongestionTestResults.ToList())
                                {
                                    @foreach (var flowEntry in algEntry.Value.ToList())
                                    {
                                        <tr>
                                            <td class="fw-bold text-start ps-2">@algEntry.Key - @GetNodeLabel(flowEntry.Key)</td>
                                            @foreach (var dataPoint in flowEntry.Value.ToList())
                                            {
                                                <td>@dataPoint.AverageLatency.ToString("F0")</td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted fst-italic py-5">
                        <p>Nessun dato disponibile.<br>Abilita lo scenario di congestione nel pannello "Controllo Simulazione" prima di avviare una simulazione per vedere i risultati.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<Node> AllNodes { get; set; } = new List<Node>();

    private string GetNodeLabel(string nodeId)
    {
        return AllNodes.FirstOrDefault(n => n.Id == nodeId)?.Label ?? nodeId;
    }

    protected override void OnInitialized()
    {
        // Si iscrive all'evento di cambiamento dello stato.
        AnalysisState.OnChange += StateHasChanged;
        // Si iscrive all'evento di aggiornamento del grafico per la scalabilità
        AnalysisState.OnScalabilityResultAdded += UpdateScalabilityChart;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Aggiorna il grafico ogni volta che i dati cambiano
        await UpdateLinkFailureChart();
        await UpdateCongestionChart();
    }

    private async Task UpdateLinkFailureChart()
    {
        // Prepara i dati per il grafico, creando una serie per ogni algoritmo
        var datasets = new List<object>();
        var labels = new List<string>();

        // Lista di colori per distinguere le linee dei diversi flussi
        var flowColors = new[] { "rgb(255, 99, 132)", "rgb(54, 162, 235)", "rgb(255, 206, 86)", "rgb(75, 192, 192)", "rgb(153, 102, 255)", "rgb(255, 159, 64)" };
        int colorIndex = 0;

        // Itera su ogni algoritmo (Dijkstra, AI)
        foreach (var algEntry in AnalysisState.LinkFailureFlowResults)
        {
            var algorithmName = algEntry.Key;
            var flows = algEntry.Value;

            // Itera su ogni flusso (sensore) per quell'algoritmo
            foreach (var flowEntry in flows)
            {
                var sourceId = flowEntry.Key;
                var dataPoints = flowEntry.Value;

                if (!dataPoints.Any()) continue;

                // Estrae le etichette del tempo (asse X) una sola volta
                if (!labels.Any())
                {
                    labels = dataPoints.Select(d => d.Time + "s").ToList();
                }

                datasets.Add(new
                {
                    label = $"{algorithmName} - {GetNodeLabel(sourceId)}", // Es. "Dijkstra - Sensor (Traffic)"
                    data = dataPoints.Select(d => d.DeliveryRate),
                    borderColor = flowColors[colorIndex % flowColors.Length],
                    backgroundColor = flowColors[colorIndex % flowColors.Length],
                    tension = 0.1
                });
                colorIndex++;
            }
        }

        await JSRuntime.InvokeVoidAsync("chartInterop.createOrUpdateChart", "linkFailureChart", labels, datasets, "Tempo di Simulazione (s)", "Tasso di Consegna (%)");
    }

    private async Task UpdateCongestionChart()
    {
        var datasets = new List<object>();
        var labels = new List<string>();

        var flowColors = new[] { "rgb(153, 102, 255)", "rgb(255, 159, 64)", "rgb(255, 99, 132)", "rgb(54, 162, 235)", "rgb(255, 206, 86)", "rgb(75, 192, 192)" };
        int colorIndex = 0;

        foreach (var algEntry in AnalysisState.CongestionTestResults)
        {
            foreach (var flowEntry in algEntry.Value)
            {
                if (!flowEntry.Value.Any()) continue;

                if (!labels.Any())
                {
                    labels = flowEntry.Value.Select(d => d.Time + "s").ToList();
                }

                datasets.Add(new
                {
                    label = $"{algEntry.Key} - Latenza {GetNodeLabel(flowEntry.Key)}",
                    data = flowEntry.Value.Select(d => d.AverageLatency),
                    borderColor = flowColors[colorIndex % flowColors.Length],
                    backgroundColor = flowColors[colorIndex % flowColors.Length],
                    tension = 0.1
                });
                colorIndex++;
            }
        }

        await JSRuntime.InvokeVoidAsync("chartInterop.createOrUpdateChart", "congestionChart", labels, datasets, "Tempo di Simulazione (s)", "Latenza Media (ms)");
    }

    private void ClearResults() => AnalysisState.Clear();

    private string FormatDetailedPath(List<PathSegment> path)
    {
        if (path == null || !path.Any())
        {
            return "Percorso non disponibile.";
        }

        var pathString = new System.Text.StringBuilder();
        pathString.Append(GetNodeLabel(path.First().StartNodeId));

        foreach (var segment in path)
        {
            pathString.Append($" --[{segment.LinkId}:{segment.LinkTechnology}]--> {GetNodeLabel(segment.EndNodeId)}");
        }

        return pathString.ToString();
    }

    private async Task ExportCardAsImage(string elementId, string fileName)
    {
        await JSRuntime.InvokeVoidAsync("exportCardAsImage", elementId, fileName);
    }

    private async void UpdateScalabilityChart()
    {
        // Usiamo ToList() per evitare problemi di concorrenza
        var allResults = AnalysisState.ScalabilityResults.ToList();

        if (!allResults.Any()) return;

        // Raggruppa i dati per DataRate (ogni gruppo diventa una linea nel grafico)
        var groupedData = allResults.GroupBy(r => new { r.Algorithm, r.DataRate })
                                    .OrderBy(g => g.Key.DataRate)
                                    .ThenBy(g => g.Key.Algorithm);

        var latencyDatasets = new List<object>();
        var deliveryDatasets = new List<object>();

        string[] colors = { "#007bff", "#dc3545", "#28a745", "#fd7e14", "#6f42c1", "#17a2b8" };
        int colorIndex = 0;

        foreach (var group in groupedData)
        {
            // Dati per Latenza (Grafico 1)
            var latencyPoints = group.OrderBy(r => r.SensorCount)
                                     .Select(r => new { x = r.SensorCount, y = r.AverageLatency })
                                     .ToList();

            // Dati per Delivery Rate (Grafico 2)
            var deliveryPoints = group.OrderBy(r => r.SensorCount)
                                      .Select(r => new { x = r.SensorCount, y = r.DeliveryRate })
                                      .ToList();

            string label = $"{group.Key.Algorithm} - {group.Key.DataRate} KB/s";
            var borderDash = group.Key.Algorithm.Contains("AI") ? new[] { 5, 5 } : new int[] { };
            var color = colors[colorIndex % colors.Length];

            // Dataset Latenza
            latencyDatasets.Add(new
            {
                label = label,
                data = latencyPoints,
                borderColor = color,
                backgroundColor = color,
                borderDash = borderDash,
                tension = 0.3,
                fill = false
            });

            // Dataset Delivery
            deliveryDatasets.Add(new
            {
                label = label,
                data = deliveryPoints,
                borderColor = color,
                backgroundColor = color,
                borderDash = borderDash,
                tension = 0.3,
                fill = false
            });

            colorIndex++;
        }

        await InvokeAsync(async () =>
        {
            // Aggiorna Grafico 1
            await JSRuntime.InvokeVoidAsync("chartInterop.updateScalabilityChart", "scalabilityChart", latencyDatasets);
            // Aggiorna Grafico 2 (NUOVO)
            await JSRuntime.InvokeVoidAsync("chartInterop.updateScalabilityDeliveryChart", "scalabilityDeliveryChart", deliveryDatasets);

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AnalysisState.OnChange -= StateHasChanged;
        AnalysisState.OnScalabilityResultAdded -= UpdateScalabilityChart;
    }
}