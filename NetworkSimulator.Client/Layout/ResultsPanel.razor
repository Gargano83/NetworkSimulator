@using NetworkSimulator.Shared

<div class="card bg-light mt-3">
    <div class="card-header">
        <strong>Riepilogo Calcolo Percorso</strong>
    </div>
    <div class="card-body">
        <p class="card-text mb-1">
            <strong>Algoritmo:</strong>
            <span class="badge bg-primary">@AlgorithmName</span>
        </p>
        <p class="card-text mb-1">
            <strong>Metrica di Ottimizzazione:</strong>
            <span class="text-capitalize">@Metric</span>
        </p>
        <hr />
        @if (Result != null && Result.Error == null && Result.Path != null)
        {
            <p class="card-text mb-1">
                <strong>Percorso Scelto:</strong>
                <code>@GetPathWithLabels()</code>
            </p>
            <p class="card-text mb-1">
                <strong>Costo Totale:</strong>
                <span class="fw-bold text-success">@Result.TotalCost.ToString("F2")</span>
            </p>
        }
        else if (Result != null)
        {
            <p class="card-text mb-1 text-danger">
                <strong>Errore:</strong> @Result.Error
            </p>
        }
    </div>
</div>

@code {
    [Parameter]
    public PathResult? Result { get; set; }

    [Parameter]
    public string AlgorithmName { get; set; } = "N/D";

    [Parameter]
    public string Metric { get; set; } = "N/D";

    /// <summary>
    /// NUOVO: Riceve la lista completa di tutti i nodi della topologia.
    /// </summary>
    [Parameter]
    public List<Node> AllNodes { get; set; } = new List<Node>();

    /// <summary>
    /// NUOVO: Metodo helper per tradurre la lista di ID in una stringa di etichette.
    /// </summary>
    private string GetPathWithLabels()
    {
        if (Result?.Path == null || !AllNodes.Any())
        {
            return "N/D";
        }

        // Per ogni ID nel percorso, trova il nodo corrispondente e prendi la sua etichetta.
        var labels = Result.Path.Select(nodeId =>
            AllNodes.FirstOrDefault(node => node.Id == nodeId)?.Label ?? nodeId
        );

        return string.Join(" → ", labels);
    }
}